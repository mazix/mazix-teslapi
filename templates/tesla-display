#!/bin/bash
# tesla-display — switch between two remote-display backends:
#   kasmvnc : Xvnc on :1, software rendering, original stack
#   hwaccel : x11vnc + websockify+noVNC on :0, V3D-accelerated
#
# Both stacks stay installed; only one serves :443 at a time. The
# switch rewrites the nft 443 redirect target and enables/disables the
# relevant services. Boot-default lives in /etc/tesla-display/active.
# Self-elevate before anything else. Inner write_nft / save_default /
# systemctl calls all need root; rather than littering the script with
# `sudo` (which can re-prompt in non-TTY contexts) we re-exec ourselves
# under NOPASSWD-protected sudo and run the entire script as root.
if [ "${EUID:-$(id -u)}" -ne 0 ]; then
    exec sudo -n "$0" "$@"
fi

set -euo pipefail

# DEBUG: log every invocation so we can see what's happening when the GUI
# triggers a switch (especially the kasmvnc->hwaccel direction).
LOG="/tmp/tesla-display.log"
{
    echo "=================================================="
    echo "[$(date '+%H:%M:%S.%3N')] CALL pid=$$ ppid=$PPID euid=$EUID args=[$*]"
    echo "  caller: $(ps -o comm= -p $PPID 2>/dev/null)"
} >> "$LOG" 2>&1

log_step() {
    echo "[$(date '+%H:%M:%S.%3N')] pid=$$ $*" >> "$LOG" 2>&1
}

trap 'log_step "EXIT exit_code=$?"' EXIT

CONFIG="/etc/tesla-display/active"
NFT_CONF="/etc/nftables.d/port-redirect.conf"
PI_UID=1000

# user_systemctl: dispatch a `systemctl --user` for pi regardless of whether
# we're running as pi or as root (the GUI calls us via sudo). Linger keeps
# pi's user manager alive even with no login session.
user_systemctl() {
    if [ "$(id -u)" = "$PI_UID" ]; then
        systemctl --user "$@"
    else
        runuser -u pi -- env XDG_RUNTIME_DIR="/run/user/$PI_UID" systemctl --user "$@"
    fi
}

usage() {
    cat <<EOF
Usage:
  tesla-display switch kasmvnc|hwaccel    Switch active backend now
  tesla-display status                    Show current state
  tesla-display set-default kasmvnc|hwaccel
                                          Change boot default only

Active backend = the one whose listener nft 443 redirects to.
EOF
    exit 1
}

current_active() {
    [ -f "$CONFIG" ] && cat "$CONFIG" || echo "kasmvnc"
}

write_nft() {
    local port="$1"
    # We run as root via sudo from the GUI; inner `sudo X` re-enters sudo
    # and Pi's sudoers can be TTY-strict in non-interactive paths. Call
    # the binaries directly instead — equally privileged, more reliable.
    mkdir -p "$(dirname "$NFT_CONF")"
    cat > "$NFT_CONF" <<EOF
# tesla-station port redirect (managed by tesla-display)
# fib daddr type local restricts to packets aimed at this host.
table inet portfwd {
  chain prerouting {
    type nat hook prerouting priority dstnat; policy accept;
    fib daddr type local tcp dport 443 redirect to :$port
  }
}
EOF
    nft delete table inet portfwd 2>/dev/null || true
    nft -f "$NFT_CONF"
}

save_default() {
    mkdir -p "$(dirname "$CONFIG")"
    printf '%s\n' "$1" > "$CONFIG"
}

switch_to_kasmvnc() {
    # set +e block: in the previous version, `set -e` + a `set -euo pipefail`
    # script + `user_systemctl ... || true` interacted in a way that the
    # function still aborted at exit_code=1 right after the kasmvnc disable
    # step on a *third* switch attempt (log captured proof). The fix is to
    # disable errexit for the whole switch sequence and record each step's
    # rc so we can see exactly where things go wrong if they do.
    set +e
    log_step "switch_to_kasmvnc: stopping hwaccel"
    systemctl disable --now websockify-tls.service x11vnc.service 2>/dev/null
    log_step "  rc=$? (stop hwaccel; non-zero ok if already stopped)"
    log_step "switch_to_kasmvnc: enabling kasmvnc user service"
    user_systemctl enable --now kasmvnc.service
    log_step "  rc=$? (enable kasmvnc)"
    log_step "switch_to_kasmvnc: writing nft 8443"
    write_nft 8443
    log_step "  rc=$? (write_nft 8443)"
    log_step "switch_to_kasmvnc: save_default kasmvnc"
    save_default kasmvnc
    log_step "  rc=$? (save_default)"
    log_step "switch_to_kasmvnc: done"
    set -e
}

switch_to_hwaccel() {
    set +e
    log_step "switch_to_hwaccel: stopping kasmvnc user service"
    user_systemctl disable --now kasmvnc.service 2>/dev/null
    log_step "  rc=$? (disable kasmvnc; non-zero ok if already stopped)"
    log_step "switch_to_hwaccel: enabling x11vnc"
    systemctl enable --now x11vnc.service
    log_step "  rc=$? (enable x11vnc)"
    log_step "switch_to_hwaccel: enabling websockify-tls"
    systemctl enable --now websockify-tls.service
    log_step "  rc=$? (enable websockify-tls)"
    log_step "switch_to_hwaccel: writing nft 8444"
    write_nft 8444
    log_step "  rc=$? (write_nft 8444)"
    log_step "switch_to_hwaccel: save_default hwaccel"
    save_default hwaccel
    log_step "  rc=$? (save_default)"
    log_step "switch_to_hwaccel: done"
    set -e
}

cmd="${1:-status}"
case "$cmd" in
    switch)
        target="${2:?backend name required: kasmvnc or hwaccel}"
        case "$target" in
            kasmvnc) switch_to_kasmvnc; echo "Now active: kasmvnc" ;;
            hwaccel) switch_to_hwaccel; echo "Now active: hwaccel" ;;
            *) echo "unknown backend: $target"; usage ;;
        esac
        ;;
    status)
        echo "Configured default : $(current_active)"
        echo
        printf "%-13s : %s\n" "KasmVNC"    "$(user_systemctl is-active kasmvnc.service 2>/dev/null)"
        printf "%-13s : %s\n" "x11vnc"     "$(systemctl is-active x11vnc.service 2>/dev/null)"
        printf "%-13s : %s\n" "websockify" "$(systemctl is-active websockify-tls.service 2>/dev/null)"
        local_port=$(sudo nft list table inet portfwd 2>/dev/null | grep -oP 'redirect to :\K\d+' | head -1 || true)
        echo
        printf "%-13s : %s\n" "443 redirect" "${local_port:-none}"
        ;;
    set-default)
        target="${2:?backend name required}"
        case "$target" in
            kasmvnc|hwaccel) save_default "$target"; echo "Boot default: $target" ;;
            *) echo "unknown backend: $target"; usage ;;
        esac
        ;;
    *)
        usage
        ;;
esac
