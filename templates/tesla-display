#!/bin/bash
# tesla-display — switch between two remote-display backends:
#   kasmvnc : Xvnc on :1, software rendering, original stack
#   hwaccel : x11vnc + websockify+noVNC on :0, V3D-accelerated
#
# Both stacks stay installed; only one serves :443 at a time. The
# switch rewrites the nft 443 redirect target and enables/disables the
# relevant services. Boot-default lives in /etc/tesla-display/active.
#
# Self-elevate: every code path here needs root (sudo systemctl / sudo
# nft / sudo tee). When invoked from the GUI's `sudo subprocess.run`,
# stdin isn't a TTY so any *inner* sudo silently fails and the switch
# ends up half-applied. Re-exec ourselves as root immediately via the
# NOPASSWD rule installed in /etc/sudoers.d/tesla-display, then every
# inner `sudo X` is root-to-root and just works.
if [ "${EUID:-$(id -u)}" -ne 0 ]; then
    exec sudo -n "$0" "$@"
fi

set -euo pipefail

CONFIG="/etc/tesla-display/active"
NFT_CONF="/etc/nftables.d/port-redirect.conf"
PI_UID=1000

# user_systemctl: dispatch a `systemctl --user` for pi regardless of whether
# we're running as pi or as root (the GUI calls us via sudo). Linger keeps
# pi's user manager alive even with no login session.
user_systemctl() {
    if [ "$(id -u)" = "$PI_UID" ]; then
        systemctl --user "$@"
    else
        runuser -u pi -- env XDG_RUNTIME_DIR="/run/user/$PI_UID" systemctl --user "$@"
    fi
}

usage() {
    cat <<EOF
Usage:
  tesla-display switch kasmvnc|hwaccel    Switch active backend now
  tesla-display status                    Show current state
  tesla-display set-default kasmvnc|hwaccel
                                          Change boot default only

Active backend = the one whose listener nft 443 redirects to.
EOF
    exit 1
}

current_active() {
    [ -f "$CONFIG" ] && cat "$CONFIG" || echo "kasmvnc"
}

# From here on every command runs as root (see self-elevate at top),
# so inner `sudo X` would re-enter sudo — and Pi's sudoers can require
# a TTY, which kills the GUI path. Call the binaries directly instead.

write_nft() {
    local port="$1"
    mkdir -p "$(dirname "$NFT_CONF")"
    cat > "$NFT_CONF" <<EOF
# tesla-station port redirect (managed by tesla-display)
# fib daddr type local restricts to packets aimed at this host.
table inet portfwd {
  chain prerouting {
    type nat hook prerouting priority dstnat; policy accept;
    fib daddr type local tcp dport 443 redirect to :$port
  }
}
EOF
    nft delete table inet portfwd 2>/dev/null || true
    nft -f "$NFT_CONF"
}

save_default() {
    mkdir -p "$(dirname "$CONFIG")"
    printf '%s\n' "$1" > "$CONFIG"
}

switch_to_kasmvnc() {
    # Stop hwaccel backend (system services; we're root)
    systemctl disable --now websockify-tls.service x11vnc.service 2>/dev/null || true
    # Start kasmvnc (user service; linger keeps pi's user manager alive)
    user_systemctl enable --now kasmvnc.service
    write_nft 8443
    save_default kasmvnc
    # Safety net: if user-service start silently no-op'd (seen twice in
    # production via GUI sudo path), retry once.
    user_systemctl is-active kasmvnc.service >/dev/null 2>&1 \
        || user_systemctl start kasmvnc.service
}

switch_to_hwaccel() {
    # Stop kasmvnc (user service)
    user_systemctl disable --now kasmvnc.service 2>/dev/null || true
    # Start hwaccel backend
    systemctl enable --now x11vnc.service
    systemctl enable --now websockify-tls.service
    write_nft 8444
    save_default hwaccel
    # Safety net mirrors switch_to_kasmvnc — retry if the unit isn't
    # active after enable --now.
    systemctl is-active x11vnc.service >/dev/null 2>&1 \
        || systemctl start x11vnc.service
    systemctl is-active websockify-tls.service >/dev/null 2>&1 \
        || systemctl start websockify-tls.service
}

cmd="${1:-status}"
case "$cmd" in
    switch)
        target="${2:?backend name required: kasmvnc or hwaccel}"
        case "$target" in
            kasmvnc) switch_to_kasmvnc; echo "Now active: kasmvnc" ;;
            hwaccel) switch_to_hwaccel; echo "Now active: hwaccel" ;;
            *) echo "unknown backend: $target"; usage ;;
        esac
        ;;
    status)
        echo "Configured default : $(current_active)"
        echo
        printf "%-13s : %s\n" "KasmVNC"    "$(user_systemctl is-active kasmvnc.service 2>/dev/null)"
        printf "%-13s : %s\n" "x11vnc"     "$(systemctl is-active x11vnc.service 2>/dev/null)"
        printf "%-13s : %s\n" "websockify" "$(systemctl is-active websockify-tls.service 2>/dev/null)"
        local_port=$(nft list table inet portfwd 2>/dev/null | grep -oP 'redirect to :\K\d+' | head -1 || true)
        echo
        printf "%-13s : %s\n" "443 redirect" "${local_port:-none}"
        ;;
    set-default)
        target="${2:?backend name required}"
        case "$target" in
            kasmvnc|hwaccel) save_default "$target"; echo "Boot default: $target" ;;
            *) echo "unknown backend: $target"; usage ;;
        esac
        ;;
    *)
        usage
        ;;
esac
