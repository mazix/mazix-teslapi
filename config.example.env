# Copy to config.env and fill in YOUR values.
# Never commit config.env (it's in .gitignore).

# === Wi-Fi hotspot Tesla connects to ===
HOTSPOT_SSID="PiTesla"
HOTSPOT_PASSWORD="ChangeMeNow123"
# Default uses RFC 5737 TEST-NET-2 (198.51.100.0/24). This is a documentation
# range — not routable on the public internet and NOT in RFC 1918, so
# Tesla's Chromium Private Network Access (PNA) check treats it as a public
# address and lets clients reach the Pi. Using 10.42.0.1 (NM's default) here
# would break Tesla browser access — see docs/troubleshooting.md for the full
# write-up. Other safe choices: 192.0.2.1 (TEST-NET-1), 203.0.113.1 (TEST-NET-3).
HOTSPOT_IP="198.51.100.1"
HOTSPOT_BAND="bg"                # bg = 2.4 GHz (Pi 5 onboard WiFi AP only does 2.4)

# === Domain & TLS (Let's Encrypt cert) ===
# Use your own domain. You DO need a public A record pointing at HOTSPOT_IP
# above — see docs/prerequisites.md. Modern browsers (Tesla, macOS with
# iCloud Private Relay, Chrome Secure DNS) do DNS-over-HTTPS and bypass the
# Pi's local dnsmasq hijack, so the public answer has to match the local one.
# Since HOTSPOT_IP is in TEST-NET space, no real internet host can use it.
DOMAIN="pi.example.com"
LE_EMAIL="you@example.com"

# === Cloudflare API (DNS-01 challenge) ===
# Create a scoped token at:
#   Cloudflare → My Profile → API Tokens → Create Token
#   Template: "Edit zone DNS"
#   Zone Resources: Include → Specific zone → your domain
CF_TOKEN=""
CF_ACCOUNT_ID=""                 # Usually empty for scoped tokens

# === KasmVNC display ===
KASMVNC_RES_W=1280
KASMVNC_RES_H=720
KASMVNC_FPS=24

# === Bluetooth (Tesla audio source) ===
# Tesla refuses to negotiate A2DP for devices it categorises as "Phone"
# unless the user explicitly toggles "Media Audio" in the car's BT
# settings (and that toggle is missing in many software versions).
# Advertising as "Audio/Video — Headphones" makes Tesla treat the Pi as
# a media device by default and A2DP opens automatically on connect.
#
# Common values:
#   0x240404 = Audio/Video, Headphones                (recommended)
#   0x240414 = Audio/Video, Wearable Headset Device
#   0x240418 = Audio/Video, Car Audio
#   0x5A020C = Phone, smartphone (older recommendation — see above)
BT_DEVICE_CLASS="0x240404"
BT_DEVICE_ALIAS="iPhone-Pi"      # name Tesla will show

# === Misc ===
PI_USER="${USER}"
WIFI_IFACE="wlan0"
TETHER_IFACE_HINT="eth1"         # iPhone tether interface name (auto-detected)
